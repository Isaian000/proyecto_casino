{
  "name": "proyecto_casino",
  "version": "1.2.0",
  "description": "Casino en linea: backend Node.js + Express + TypeScript + MongoDB Atlas con autenticacion local y Google OAuth, sistema de amigos, billetera con operaciones atomicas, lobbies, subida de avatars con Cloudinary y consumo de API externa de tipo de cambio. Frontend HTML/CSS/JS adaptado del proyecto IA.",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --watch src --ext ts,js,html,css --exec ts-node src/index.ts",
    "build": "rm -rf dist && tsc && npm run copy:assets",
    "copy:assets": "shx mkdir -p dist/views dist/public dist/docs && shx cp -r src/views/* dist/views/ && shx cp -r src/public/* dist/public/ && shx cp -r src/docs/* dist/docs/",
    "start": "node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Isaian000/proyecto_casino.git"
  },
  "keywords": ["casino", "express", "typescript", "mongodb", "mongoose"],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Isaian000/proyecto_casino/issues"
  },
  "homepage": "https://github.com/Isaian200/proyecto_casino#readme",
  "dependencies": {
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.5",
    "streamifier": "^0.1.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.12.0",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/streamifier": "^0.1.2",
    "rimraf": "^5.0.10",
    "shx": "^0.3.4",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2"
  }
}